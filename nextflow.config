process.container = 'selkamandcci/micrite-screen:0.0.1'

profiles {
    singularity {
        singularity.enabled = true
    }
    docker {
        docker.enabled = true
    }
    apptainer {
        apptainer.enabled = true
    }

    researchvm {
        singularity.enabled = true

        params{
          threads = 16
          threads_kraken = 16
          preload_size = "128G"
        }
    }
}

report {
    enabled = true
    overwrite = true
    file = "results/${params.sampleid}.report.html"
}

timeline {
    enabled = true
    overwrite = true
    file = "results/${params.sampleid}.timeline.html"
}

dag {
    enabled = false
    overwrite = true
    file = "results/${params.sampleid}.dag.html"
}


